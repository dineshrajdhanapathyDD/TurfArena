# ─── AWS Configuration ───────────────────────────────────────────
# Required for DynamoDB and EventBridge integration.
# When AWS_REGION is not set, the app falls back to mock data.

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# ─── DynamoDB Table Names (optional overrides) ───────────────────
# Defaults are used if not set (e.g. TurfArena_Players)

DYNAMODB_TABLE_PLAYERS=TurfArena_Players
DYNAMODB_TABLE_TEAMS=TurfArena_Teams
DYNAMODB_TABLE_TOURNAMENTS=TurfArena_Tournaments
DYNAMODB_TABLE_TURFS=TurfArena_Turfs
DYNAMODB_TABLE_PLAYER_STATS=TurfArena_PlayerStats
DYNAMODB_TABLE_MATCHES=TurfArena_Matches
DYNAMODB_TABLE_BOOKINGS=TurfArena_Bookings
DYNAMODB_TABLE_LEADERBOARDS=TurfArena_Leaderboards
DYNAMODB_TABLE_REGISTRATIONS=TurfArena_Registrations

# ─── EventBridge ─────────────────────────────────────────────────
EVENTBRIDGE_BUS_NAME=TurfArena-Events

# ─── App Configuration ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
